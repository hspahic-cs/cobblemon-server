# World data
world/
world_nether/
world_the_end/
*.mca
*.mcabackup
session.lock

# Player data
playerdata/
advancements/
stats/
banned-players.json
banned-ips.json
usercache.json
whitelist.json
ops.json

# Logs and crash reports
logs/
crash-reports/
debug/

# Server runtime files
libraries/
versions/
server.jar
fabric-server-launch.jar
fabric-installer-*.jar
fabric-server-launcher.properties
eula.txt

# Reference clones of upstream mod sources (kept locally for dev,
# not vendored in this repo — see docs/upstream-sources.md).
# Anchored to repo root: does NOT ignore modpack/mods (packwiz manifests).
/reference/*
!/reference/README.md

# Live-server mod jars (CI builds + uploads to GitHub Releases)
server-mods/*.jar

# Modpack export artifacts (built on demand, not tracked)
modpack/*.mrpack
modpack/mods/*.jar

# Cobblemon runtime data
showdown/
cobblemonplayerdata/
pokedex/
pokemon/
legendary-monuments-data/

# Gradle build outputs (custom-mods/)
**/.gradle/
**/build/
**/.kotlin/
**/.idea/

# moddev's local runServer output (custom-mods/<mod>/run/) — generated worlds,
# downloaded runtime mod jars, world data. Never committed.
custom-mods/*/run/

# MkDocs build output + local venv
/site/
/.docs-venv/

# Python (ops/ scripts and services)
**/__pycache__/
*.pyc

# Misc
*.lock
.DS_Store
Thumbs.db
