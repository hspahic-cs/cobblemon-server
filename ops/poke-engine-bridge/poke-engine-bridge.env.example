# Bridge service runtime config (bash-sourced by the systemd unit).
# Copy to /etc/default/poke-engine-bridge on the VM (handled by install.sh).
#
# WORKERS: uvicorn worker processes. Each worker handles one /pick at a time
# and pegs ~1 core during MCTS. Tune per the VM's CPU budget. Each worker
# adds ~150 MB RSS for foul-play's Smogon priors.
WORKERS=4

# PORT: bind on 127.0.0.1 only (bridge is local-only by architecture).
PORT=8642

# BRIDGE_FAILURE_LOG_DIR: where to append pick_failures.jsonl — one replayable
# line per pick foul-play couldn't process (verbatim request + error + trace),
# for batch triage with replay.py. Defaults to BRIDGE_BATTLE_LOG_DIR when unset,
# so failures are captured wherever battle logging is already on.
# BRIDGE_FAILURE_LOG_DIR=/opt/poke-engine-bridge/battle-logs
